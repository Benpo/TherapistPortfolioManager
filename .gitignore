.DS_Store
Thumbs.db

# Environment & secrets
.env
.env.*

# Local scripts (not deployed) — except the docs-rot gate tooling, which the
# pre-push hook and CI (deploy.yml) must run, so it is version-controlled.
scripts/*
!scripts/lib/
!scripts/docs-gate.js
!scripts/gen-help-map.js
!scripts/ci-resolve-docs-range.sh
!scripts/cf-await-promotion.sh

