# Lemon Squeezy (license activation API)
LEMON_SQUEEZY_API_KEY=your_api_key_here

# Cloudflare Cache Purge (post-deploy cache invalidation)
# Zone ID: CF dashboard → sessionsgarden.app → Overview → right sidebar
CF_ZONE_ID=your_zone_id_here
# API Token: CF dashboard → My Profile → API Tokens → Create Token → "Cache Purge" permission
CF_PURGE_TOKEN=your_api_token_here
